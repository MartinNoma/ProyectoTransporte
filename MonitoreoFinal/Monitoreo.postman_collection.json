{
  "info": {
    "name": "MS Monitoreo",
    "description": "Coleccion lista para probar el microservicio de Monitoreo. Ejecuta primero Login, copia el token, y usalo en las demas requests (ya estan preconfiguradas para usar la variable {{token}} automaticamente).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8084" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "1. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    pm.collectionVariables.set('token', jsonData.token);",
              "    console.log('Token guardado automaticamente');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "2. Listar Alertas",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/api/monitoreo/alerta",
          "host": ["{{base_url}}"],
          "path": ["api", "monitoreo", "alerta"]
        }
      }
    },
    {
      "name": "3. Crear Alerta",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tipoAlerta\": \"CRITICA\",\n  \"descripcion\": \"Temperatura del servidor supera 90 grados\",\n  \"estado\": \"ACTIVA\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/monitoreo/alerta",
          "host": ["{{base_url}}"],
          "path": ["api", "monitoreo", "alerta"]
        }
      }
    },
    {
      "name": "4. Actualizar Alerta",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tipoAlerta\": \"INFO\",\n  \"descripcion\": \"Problema resuelto\",\n  \"estado\": \"RESUELTA\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/monitoreo/alerta/1",
          "host": ["{{base_url}}"],
          "path": ["api", "monitoreo", "alerta", "1"]
        }
      }
    },
    {
      "name": "5. Eliminar Alerta",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/api/monitoreo/alerta/1",
          "host": ["{{base_url}}"],
          "path": ["api", "monitoreo", "alerta", "1"]
        }
      }
    }
  ]
}
